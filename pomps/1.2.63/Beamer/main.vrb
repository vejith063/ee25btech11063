\frametitle{Python: plot.py}
\begin{lstlisting}[language=Python]
x_labels = [f'$x_{i}$={val}' for i, val in enumerate(x_nodes)]
plt.xticks(x_nodes, x_labels, fontsize=11)

plt.xlim(-0.05, 1.05)
plt.ylim(0, 1.1)

plt.legend(loc='upper left', fontsize=11)
plt.grid(True, linestyle='--', alpha=0.5)

# Show the plot
plt.tight_layout()
plt.savefig("simpson.png")
plt.show()
\end{lstlisting}
